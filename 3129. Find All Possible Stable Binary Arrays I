class Solution(object):
    def numberOfStableArrays(self, zero, one, limit):
        """
        :type zero: int
        :type one: int
        :type limit: int
        :rtype: int
        """
        MOD = 10**9 + 7
        dp = [[[0 for _ in range(2)] for _ in range(one + 1)] for _ in range(zero + 1)]
        
        # Base cases for arrays with only 0s
        for i in range(min(zero, limit) + 1):
            dp[i][0][0] = 1
        
        # Base cases for arrays with only 1s
        for j in range(min(one, limit) + 1):
            dp[0][j][1] = 1
        
        for i in range(1, zero + 1):
            for j in range(1, one + 1):
                # Ways to end with 0: add 0 to previous arrays with i-1 zeros and j ones
                dp[i][j][0] = (dp[i-1][j][0] + dp[i-1][j][1]) % MOD
                if i - limit - 1 >= 0:
                    dp[i][j][0] = (dp[i][j][0] - dp[i - limit - 1][j][1] + MOD) % MOD
                
                # Ways to end with 1: add 1 to previous arrays with i zeros and j-1 ones
                dp[i][j][1] = (dp[i][j-1][0] + dp[i][j-1][1]) % MOD
                if j - limit - 1 >= 0:
                    dp[i][j][1] = (dp[i][j][1] - dp[i][j - limit - 1][0] + MOD) % MOD
        
        return (dp[zero][one][0] + dp[zero][one][1]) % MOD
