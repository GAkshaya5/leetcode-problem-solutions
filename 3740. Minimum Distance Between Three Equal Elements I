class Solution {
public:
    int minimumDistance(vector<int>& nums) {
        // Map to store all indices for each number
        unordered_map<int, vector<int>> indices;
        for (int i = 0; i < nums.size(); ++i) {
            indices[nums[i]].push_back(i);
        }

        int min_dist = INT_MAX;
        bool found = false;

        for (auto const& [val, pos] : indices) {
            // We need at least 3 occurrences to form a "good" tuple
            if (pos.size() >= 3) {
                found = true;
                // Check every consecutive triplet (a, b, c)
                // The distance is minimized when the indices are closest
                for (int i = 0; i <= (int)pos.size() - 3; ++i) {
                    int dist = 2 * (pos[i + 2] - pos[i]);
                    min_dist = min(min_dist, dist);
                }
            }
        }

        return found ? min_dist : -1;
    }
};
