class Solution {
    public void nextPermutation(int[] nums) {
        int i = nums.length - 2;
        
        // 1. Find the first decreasing element from the right
        while (i >= 0 && nums[i] >= nums[i + 1]) {
            i--;
        }

        // 2. If the entire array is decreasing, i will be -1
        if (i >= 0) {
            int j = nums.length - 1;
            // 3. Find the number just larger than nums[i] to swap with
            while (nums[j] <= nums[i]) {
                j--;
            }
            swap(nums, i, j);
        }

        // 4. Reverse the suffix to get the smallest lexicographical order
        reverse(nums, i + 1);
    }

    private void swap(int[] nums, int i, int j) {
        int temp = nums[i];
        nums[i] = nums[j];
        nums[j] = temp;
    }

    private void reverse(int[] nums, int start) {
        int end = nums.length - 1;
        while (start < end) {
            swap(nums, start, end);
            start++;
            end--;
        }
    }
}
