#include <string.h>

// Helper function must be defined BEFORE it is called
int romanValue(char c) {
    switch (c) {
        case 'I': return 1;
        case 'V': return 5;
        case 'X': return 10;
        case 'L': return 50;
        case 'C': return 100;
        case 'D': return 500;
        case 'M': return 1000;
        default: return 0;
    }
}

int romanToInt(char* s) {
    int total = 0;
    int n = strlen(s);
    
    for (int i = 0; i < n; i++) {
        int current = romanValue(s[i]);
        
        // If there is a next character and it's larger, we subtract
        if (i < n - 1 && current < romanValue(s[i + 1])) {
            total -= current;
        } else {
            total += current;
        }
    }
    
    return total;
}
