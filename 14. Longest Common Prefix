#include <string.h>
#include <stdlib.h>

char* longestCommonPrefix(char** strs, int strsSize) {
    // If the array is empty, return an empty string
    if (strsSize == 0) return "";
    
    // Start by assuming the first string is the common prefix
    // We use strdup to create a modifiable copy
    char* prefix = strdup(strs[0]);
    
    for (int i = 1; i < strsSize; i++) {
        int j = 0;
        // Compare the current prefix with the next string in the array
        // Keep moving j as long as characters match
        while (prefix[j] != '\0' && strs[i][j] != '\0' && prefix[j] == strs[i][j]) {
            j++;
        }
        
        // Shorten the prefix by placing a null terminator at the point of mismatch
        prefix[j] = '\0';
        
        // If the prefix becomes empty, we can stop early
        if (j == 0) {
            return prefix; 
        }
    }
    
    return prefix;
}
