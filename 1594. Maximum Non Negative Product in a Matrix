class Solution:
    def maxProductPath(self, grid: list[list[int]]) -> int:
        m, n = len(grid), len(grid[0])
        MOD = 10**9 + 7
        
        # We store the max and min product at each cell
        # Using a single DP table where each cell is [max_val, min_val]
        dp = [[(0, 0)] * n for _ in range(m)]
        
        # Base Case: Top-left corner
        dp[0][0] = (grid[0][0], grid[0][0])
        
        # Fill the first column
        for i in range(1, m):
            val = dp[i-1][0][0] * grid[i][0]
            dp[i][0] = (val, val)
            
        # Fill the first row
        for j in range(1, n):
            val = dp[0][j-1][0] * grid[0][j]
            dp[0][j] = (val, val)
            
        # Fill the rest of the grid
        for i in range(1, m):
            for j in range(1, n):
                curr = grid[i][j]
                
                # We can come from the top or from the left
                # Gather all 4 potential products
                options = (
                    dp[i-1][j][0] * curr,
                    dp[i-1][j][1] * curr,
                    dp[i][j-1][0] * curr,
                    dp[i][j-1][1] * curr
                )
                
                dp[i][j] = (max(options), min(options))
        
        max_prod = dp[m-1][n-1][0]
        
        # If the max product is negative, return -1 per instructions
        return max_prod % MOD if max_prod >= 0 else -1
