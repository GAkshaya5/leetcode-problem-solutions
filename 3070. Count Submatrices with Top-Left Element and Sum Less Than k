from typing import List

class Solution:
    def countSubmatrices(self, grid: List[List[int]], k: int) -> int:
        rows = len(grid)
        cols = len(grid[0])
        count = 0
        
        # prefix_sum[r][c] will store the sum of the submatrix 
        # from (0,0) to (r,c)
        prefix_sum = [[0] * cols for _ in range(rows)]
        
        for r in range(rows):
            for c in range(cols):
                # Standard 2D Prefix Sum formula:
                # Current Cell + Above + Left - Diagonal (to avoid double counting)
                
                top = prefix_sum[r-1][c] if r > 0 else 0
                left = prefix_sum[r][c-1] if c > 0 else 0
                diagonal = prefix_sum[r-1][c-1] if (r > 0 and c > 0) else 0
                
                current_sum = grid[r][c] + top + left - diagonal
                prefix_sum[r][c] = current_sum
                
                if current_sum <= k:
                    count += 1
                else:
                    # Since grid[i][j] >= 0, if current_sum > k, 
                    # all further submatrices in this row will also be > k.
                    break
                    
        return count
