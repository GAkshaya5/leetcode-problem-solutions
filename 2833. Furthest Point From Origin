class Solution {
    public int furthestDistanceFromOrigin(String moves) {
        int countL = 0;
        int countR = 0;
        int blanks = 0;

        for (char c : moves.toCharArray()) {
            if (c == 'L') countL++;
            else if (c == 'R') countR++;
            else blanks++;
        }

        // The logic: Math.abs(L - R) + blanks
        return Math.abs(countL - countR) + blanks;
    }
}
