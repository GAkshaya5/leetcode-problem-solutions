int removeDuplicates(int* nums, int numsSize) {
    // Edge case: if the array is empty, return 0
    if (numsSize == 0) return 0;

    // 'k' is our slow pointer, tracking the position of unique elements
    int k = 1; 

    // 'i' is our fast pointer, starting from the second element
    for (int i = 1; i < numsSize; i++) {
        // If we find a value that is different from the last unique value
        if (nums[i] != nums[k - 1]) {
            // Place it at the next available unique slot
            nums[k] = nums[i];
            // Move the unique counter forward
            k++;
        }
    }

    return k;
}
