class Solution {
    int count(const vector<int> &v, int x,  int y) {
        
        return x <= y ? distance(lower_bound(v.begin(), v.end(), x), upper_bound(v.begin(), v.end(), y)) : 0;
    }
public:
    int maxWalls(vector<int>& robots, vector<int>& distance, vector<int>& walls) {
        const int n = robots.size();
        vector<pair<int, int>> p(n);
        for (int i = 0; i < n; ++i) {
            p[i] = {robots[i], distance[i]};
        }
        
        sort(p.begin(), p.end());
        sort(walls.begin(), walls.end());
        int leftNum = 0, rightNum = 0;
        for (int i = 0; i < n; ++i) {
            const int nLeft = 
            max(count(walls, max((i ? p[i - 1].first : 0) + 1, p[i].first - p[i].second), p[i].first) + leftNum, count(walls, max((i ? (p[i - 1].first + p[i - 1].second) : 0) + 1,
                                                                                                                                      p[i].first - p[i].second), p[i].first) + rightNum);
            const int nRight = 
            count(walls, p[i].first, min(p[i].first + p[i].second, (i + 1 < n ? p[i + 1].first : INT_MAX) - 1)) + max(leftNum, rightNum);
            leftNum = nLeft;
            rightNum = nRight;
        }
        return max(leftNum, rightNum);
        
    }
};
