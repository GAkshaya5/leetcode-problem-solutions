class Solution {
public:
    bool canPartitionGrid(vector<vector<int>>& grid) {
        long long totalSum = 0;
        int m = grid.size();
        int n = grid[0].size();

        for (int i = 0; i < m; ++i) {
            for (int j = 0; j < n; ++j) {
                totalSum += grid[i][j];
            }
        }

        // If the total sum is odd, we can't split it into two equal integers
        if (totalSum % 2 != 0) return false;
        long long target = totalSum / 2;

        // Check horizontal cuts
        long long rowAccumulator = 0;
        for (int i = 0; i < m - 1; ++i) { // m-1 because sections must be non-empty
            for (int j = 0; j < n; ++j) {
                rowAccumulator += grid[i][j];
            }
            if (rowAccumulator == target) return true;
        }

        // Check vertical cuts
        long long colAccumulator = 0;
        for (int j = 0; j < n - 1; ++j) { // n-1 because sections must be non-empty
            for (int i = 0; i < m; ++i) {
                colAccumulator += grid[i][j];
            }
            if (colAccumulator == target) return true;
        }

        return false;
    }
};
