#include <vector>
#include <string>
#include <unordered_map>

class Solution {
public:
    bool checkStrings(string s1, string s2) {
        // We use two frequency arrays for each string: one for even indices, one for odd.
        // Since the strings consist of lowercase English letters, a size of 26 is enough.
        vector<int> countEven1(26, 0), countOdd1(26, 0);
        vector<int> countEven2(26, 0), countOdd2(26, 0);

        for (int i = 0; i < s1.length(); ++i) {
            if (i % 2 == 0) {
                countEven1[s1[i] - 'a']++;
                countEven2[s2[i] - 'a']++;
            } else {
                countOdd1[s1[i] - 'a']++;
                countOdd2[s2[i] - 'a']++;
            }
        }

        // If the counts for both groups match between s1 and s2, return true.
        return (countEven1 == countEven2 && countOdd1 == countOdd2);
    }
};
