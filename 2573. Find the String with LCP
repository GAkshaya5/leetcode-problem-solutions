class Solution:
    def findTheString(self, lcp: List[List[int]]) -> str:
        n = len(lcp)
        res = [0] * n
        char_code = 1 # Using 1-26 to represent 'a'-'z'
        
        # 1. Greedy Assignment
        for i in range(n):
            if res[i] > 0: continue
            if char_code > 26: return "" # More than 26 chars needed
            
            for j in range(i, n):
                if lcp[i][j] > 0:
                    res[j] = char_code
            char_code += 1
            
        # Convert numeric codes to actual characters
        word = "".join(chr(ord('a') + c - 1) for c in res)
        
        # 2. Validation of the LCP matrix
        # We check the property: lcp[i][j] = (1 + lcp[i+1][j+1]) if word[i] == word[j] else 0
        for i in range(n - 1, -1, -1):
            for j in range(n - 1, -1, -1):
                expected = 0
                if word[i] == word[j]:
                    if i == n - 1 or j == n - 1:
                        expected = 1
                    else:
                        expected = 1 + lcp[i+1][j+1]
                
                if lcp[i][j] != expected:
                    return ""
                    
        return word
