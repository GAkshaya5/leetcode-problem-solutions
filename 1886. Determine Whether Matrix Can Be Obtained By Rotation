#include <stdbool.h>

bool findRotation(int** mat, int matSize, int* matColSize, int** target, int targetSize, int* targetColSize) {
    int n = matSize;
    bool c[4] = {true, true, true, true}; // Checks for 0, 90, 180, and 270 degrees

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            // 0 degrees rotation
            if (mat[i][j] != target[i][j]) c[0] = false;
            
            // 90 degrees clockwise
            if (mat[i][j] != target[j][n - 1 - i]) c[1] = false;
            
            // 180 degrees clockwise
            if (mat[i][j] != target[n - 1 - i][n - 1 - j]) c[2] = false;
            
            // 270 degrees clockwise
            if (mat[i][j] != target[n - 1 - j][i]) c[3] = false;
        }
    }

    // If any of the rotations matched, return true
    return c[0] || c[1] || c[2] || c[3];
}
