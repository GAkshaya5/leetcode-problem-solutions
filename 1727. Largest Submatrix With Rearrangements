class Solution(object):
    def largestSubmatrix(self, matrix):
        m = len(matrix)
        n = len(matrix[0])
        ans = 0
        
        # Step 1: Update matrix to store heights of consecutive 1s
        for i in range(1, m):
            for j in range(n):
                if matrix[i][j] == 1:
                    matrix[i][j] += matrix[i-1][j]
        
        # Step 2: For each row, sort heights and find max rectangle
        for i in range(m):
            # Get heights in current row and sort descending
            current_row = sorted(matrix[i], reverse=True)
            
            for j in range(n):
                # Width is (j + 1), height is current_row[j]
                height = current_row[j]
                width = j + 1
                ans = max(ans, height * width)
                
        return ans
