class Solution {
    public int maxRotateFunction(int[] nums) {
        long sum = 0;
        long f0 = 0;
        int n = nums.length;

        for (int i = 0; i < n; i++) {
            sum += nums[i];
            f0 += (long) i * nums[i];
        }

        long maxVal = f0;
        long currentF = f0;

        // Iterate from 1 to n-1 to calculate F(k) based on F(k-1)
        for (int k = 1; k < n; k++) {
            // Using the derived formula: F(k) = F(k-1) + sum - n * last_element_of_previous_rotation
            // The element that moves from index (n-1) to 0 is nums[n-k]
            currentF = currentF + sum - (long) n * nums[n - k];
            maxVal = Math.max(maxVal, currentF);
        }

        return (int) maxVal;
    }
}
